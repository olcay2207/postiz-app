FROM ghcr.io/gitroomhq/postiz-app:latest
RUN printf '#!/bin/sh\nexport DATABASE_URL=${DATABASE_URL:-postgresql://postgres@dtb43w70_postiz-db:5432/dtb43w70}\nexport REDIS_URL=${REDIS_URL:-redis://postiz-redis:6379}\nnginx\nexec "$@"\n' > /entrypoint.sh && chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD ["pnpm", "run", "pm2"]
