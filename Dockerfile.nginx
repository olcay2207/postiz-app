FROM ghcr.io/gitroomhq/postiz-app:latest

ENV CUSTOM_IMAGE=olcay-attempt5
ENV DATABASE_URL=postgresql://postgres@dtb43w70_postiz-db:5432/dtb43w70
ENV REDIS_URL=redis://postiz-redis:6379
ENV MAIN_URL=https://dtb43w70.rpcl.app
ENV FRONTEND_URL=https://dtb43w70.rpcl.app
ENV NEXT_PUBLIC_BACKEND_URL=https://dtb43w70.rpcl.app/api
ENV BACKEND_INTERNAL_URL=http://localhost:3000

RUN echo "const fs=require('fs');const p=JSON.parse(fs.readFileSync('/app/package.json','utf8'));p.scripts['pm2-run']='nginx && '+p.scripts['pm2-run'];fs.writeFileSync('/app/package.json',JSON.stringify(p,null,2));console.log('pm2-run:',p.scripts['pm2-run']);" > /tmp/fix.js && node /tmp/fix.js
